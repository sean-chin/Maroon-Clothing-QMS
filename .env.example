# Copy to .env (never commit .env) and load however you prefer,
# e.g. on Windows PowerShell before starting:
#   $env:TELEGRAM_BOT_TOKEN="123:abc"; $env:ADMIN_PIN="yourpin"; npm start

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Bot username without the @, e.g. MaroonQueueBot
TELEGRAM_BOT_USERNAME=

# PIN for the /admin dashboard (change this!)
ADMIN_PIN=maroon2026

# Optional tuning
PORT=3000
STORE_CAPACITY=40
# Used only for the "estimated wait" hint (guests admitted per minute)
GUESTS_PER_MINUTE=2
