# Copy to .env (never commit .env). The app auto-loads .env and .env.local on startup.
# e.g. on Windows PowerShell before starting:
#   $env:ADMIN_PIN="yourpin"; $env:PORT="3000"; npm start

# ----- Supabase (required for Vercel / multi-instance hosting) -----
# Create a project at https://supabase.com, run supabase/migrations/*.sql in the
# SQL editor (or `supabase db push`), then paste URL + a server secret below.
SUPABASE_URL=
# Server-only (never in browser). Either:
# SUPABASE_SECRET_KEY=sb_secret_...     (Settings → API Keys → Secret keys)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...      (Legacy API Keys tab → service_role)
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PIN for the /admin dashboard (change this!)
ADMIN_PIN=maroon2026

# Optional tuning
PORT=3000
STORE_CAPACITY=30
# Used only for the "estimated wait" hint (guests admitted per minute)
GUESTS_PER_MINUTE=3
# Heads-up fires when this many guests (or fewer) are ahead
ALMOST_AHEAD=25
# Copy shown to guests for the heads-up window
ADVANCE_MINUTES=3
# How often the server re-checks waiting guests for heads-up pings (ms)
HEADS_UP_SWEEP_MS=20000
# Public guest URL for QR codes (set to your deployed URL, e.g. https://your-app.vercel.app)
PUBLIC_URL=

# ----- Email notifications (SMTP) -----
# Leave these blank to keep email off. Email switches on only when
# SMTP_HOST, SMTP_USER and SMTP_PASS are all set.
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_USER=you@gmail.com and
# SMTP_PASS set to an app password from https://myaccount.google.com/apppasswords
SMTP_HOST=
# 587 (STARTTLS, the default) or 465 (TLS)
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# "From" address on outgoing mail; defaults to SMTP_USER
SMTP_FROM=
# Set to 1 if antivirus or a proxy breaks TLS (self-signed certificate errors on Windows)
SMTP_TLS_INSECURE=

# ----- Push notifications (Web Push) -----
# The one that works with the tab closed and the phone locked. Leave blank
# to keep it off. Generate a keypair once with: npm run vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact address the push service can reach you at if it has an issue
VAPID_SUBJECT=mailto:hello@maroon.clothing
